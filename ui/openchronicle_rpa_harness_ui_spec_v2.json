{
  "project": {
    "name": "OpenChronicle RPA Harness",
    "version": "v0.2.0",
    "design_mode": "multi_rpa_provider_harness",
    "pages": [
      "实时调试控制台",
      "RPA Provider 管理与 Workflow Studio",
      "设备舰队",
      "Workflow 库",
      "Trace 回放",
      "安全审批",
      "记忆中心"
    ],
    "goal": "将原手机 RPA 调试台升级为可桥接 Android、Windows、Browser、API 等不同 RPA Provider 的统一 Harness 控制台。",
    "core_positioning": "人类演示与监督，OpenChronicle 记录学习，Codex 安全复现，Harness 负责桥接、审计、回放、稳定录制和 Skill 沉淀。",
    "target_users": [
      "Agent 开发者",
      "RPA 流程设计人员",
      "App / 桌面自动化测试工程师",
      "OpenChronicle / Codex 调试人员",
      "需要多设备自动化治理的团队"
    ],
    "source_alignment": {
      "base_prd": "openchronicle_rpa_harness_prd.md",
      "base_ui_spec": "openchronicle_rpa_harness_ui_spec.json",
      "reference_images": [
        "automation_console_with_real_time_monitoring.png",
        "rpa_provider_and_workflow_studio_dashboard.png"
      ]
    }
  },
  "product_upgrade": {
    "from": "Android 手机实时调试控制台",
    "to": "多 RPA Provider 可插拔管理控制台",
    "must_keep": [
      "实时调试页",
      "设备实时画面",
      "状态机流程",
      "Action Inspector",
      "时间线日志",
      "Skill Builder",
      "安全审批"
    ],
    "must_add": [
      "RPA Provider 管理",
      "Device Fleet 设备舰队",
      "Workflow 库",
      "录制与编辑 Studio",
      "Bridge Topology",
      "Bridge Inspector",
      "Provider Detail / Manifest Viewer",
      "Codex mock API contract"
    ],
    "design_principle": [
      "默认轻量运行，不默认全屏截图，不默认 VLM",
      "常规 workflow 走 OCR / UI tree / DOM / window tree 校验",
      "异常时才触发 keyframe / full screenshot / VLM repair hook",
      "所有 action 必须经过 safety 策略",
      "所有执行过程写入 trace.jsonl",
      "成功 trace 可以生成 workflow.json 和 skill.yaml"
    ]
  },
  "design_style": {
    "theme": "light",
    "keywords": [
      "企业级",
      "清爽",
      "科技感",
      "高密度信息",
