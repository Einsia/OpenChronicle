  "data_models": {
    "RPAProvider": {
      "name": "string",
      "platform": "android | windows | browser | api | ios | harmonyos",
      "status": "online | offline | error | reserved",
      "manifest_version": "string",
      "adapter_path": "string",
      "safety_level": "low | medium | high",
      "actions": "string[]",
      "observe_modes": "keyframe | region | full | ui_tree | dom | window_tree | logs",
      "success_rate": "number"
    },
    "RPADevice": {
      "device_id": "string",
      "provider": "string",
      "platform": "string",
      "status": "online | offline | busy | error",
      "current_target": "app package | window title | url | api endpoint",
      "last_heartbeat": "ISO datetime",
      "current_task": "string | null",
      "risk_level": "L0 | L1 | L2 | L3"
